{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "make",
            "command": "make",
            "args": [
                 "-fdiagnostics-color=always",
                "-g",
                "${workspaceFolder}/main.cpp",
                "${workspaceFolder}/calc.cpp",
                "${workspaceFolder}/convertInfix.cpp",
                "${workspaceFolder}/separator.cpp",
                "-o",
                "${workspaceFolder}/main"
            ],
            "options": {
                "cwd": "${workspaceFolder}", 
            },
            "problemMatcher": [
                "$gcc"
            ],
        }
    ]
}
