{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "build game",
            "command": "/usr/bin/g++",
            "args": [
                "-std=c++17",
                "-fcolor-diagnostics",
                "-fansi-escape-codes",
                "-g",
                "main.cpp",
                "calc.cpp",
                "convertInfix.cpp",
                "separator.cpp",
                "utility.cpp",
                "yesno.cpp",
                "-o",
                "${workspaceFolder}/main"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
